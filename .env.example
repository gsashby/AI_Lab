# ---- Model providers (set at least one; Anthropic is the default) ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Which registry entry to use by default. See lab/config.py MODEL_REGISTRY.
# Options out of the box: anthropic-default, anthropic-fast, openai-default, openai-fast
LAB_DEFAULT_MODEL=anthropic-default

# ---- Observability: LangSmith ----
# Get a key at https://smith.langchain.com (free tier is plenty for a personal lab).
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_...
LANGSMITH_PROJECT=ai-lab
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # only change if self-hosting
